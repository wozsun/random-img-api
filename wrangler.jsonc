{
  "name": "random-img-api",
  "main": "app/index.js",
  "compatibility_date": "2026-03-20",

  // Cloudflare Workers KV mode
  "vars": {
    "KV_PROVIDER": "CF"
  },

  // KV namespaces. Make sure to replace the "id" with your actual KV namespace ID.
  "kv_namespaces": [
    {
      "binding": "random-img-config",
      "id": "1eb615e1c5724a0a90f260eeb27345d2"
    }
  ]
}